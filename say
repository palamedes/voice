#!/usr/bin/env bash
# say — speak the given text out loud in the cloned voice.
#
#   ./say hello world
#   ./say --muted "Same words, muted voice."
#   ./say "Punctuation? Quote it, to be safe."
#
# Leading --flags are passed through to index_speak.py; any voice name works
# as a flag (--calm, --muted, --presenter, ...). Plays through your speakers
# (ffplay) and saves nothing permanent.
set -euo pipefail

# Resolve the project dir from this script's location, so it works no matter
# what the current working directory is.
HERE="$(cd "$(dirname "$0")" && pwd)"

flags=()
while [ $# -gt 0 ] && [[ "$1" == --* ]]; do
  flags+=("$1")
  shift
done

text="$*"
if [ -z "$text" ]; then
  echo "usage: say [--voice-flags] <text to speak>" >&2
  exit 1
fi

exec "$HERE/index-tts/.venv/bin/python" "$HERE/scripts/index_speak.py" \
  ${flags[@]+"${flags[@]}"} --text "$text" --out /tmp/say.wav --play >/dev/null 2>&1
