#!/usr/bin/env bash
# speak — narrate the given text in Jason's cloned voice and save it to output/.
#
#   ./speak hello world
#   ./speak "Punctuation? Quote it, to be safe."
#
# Saves a wav to output/ and prints the path. Doesn't play it — use ./say for that.
set -euo pipefail

# Resolve the project dir from this script's location, so it works no matter
# what the current working directory is.
HERE="$(cd "$(dirname "$0")" && pwd)"

text="$*"
if [ -z "$text" ]; then
  echo "usage: speak <text to narrate>" >&2
  exit 1
fi

out="$HERE/output/speak_$(date +%Y%m%d_%H%M%S).wav"

exec "$HERE/index-tts/.venv/bin/python" "$HERE/scripts/index_speak.py" \
  --text "$text" --out "$out"
